{
   "version": "0.2.0",
   "configurations": [
      {
         "name": "(Windows) Launch Installer",
         "type": "cppvsdbg",
         "request": "launch",
         "program": "${workspaceFolder}/build/installer/msfs2024-vfrnav_installer.exe",
         "args": [],
         "stopAtEntry": false,
         "cwd": "${workspaceFolder}",
         "environment": [],
         "console": "integratedTerminal"
      },
      {
         "name": "(Windows) Launch Server",
         "type": "cppvsdbg",
         "request": "launch",
         "program": "${workspaceFolder}/build/server/msfs2024-vfrnav_server.exe",
         "args": ["--configure"],
         "stopAtEntry": false,
         "cwd": "${workspaceFolder}",
         "environment": [
            {
               "name": "ASAN_OPTIONS",
               "value": "halt_on_error=1:verbosity=1:check_initialization_order=1:detect_leaks=0:detect_stack_use_after_return=1:alloc_dealloc_mismatch=1:detect_invalid_pointer_pairs=1:strict_string_checks=1:print_summary=1"
            },
            {
               "name": "ASAN_SYMBOLIZER_PATH",
               "value": "C:/Program Files/LLVM/bin/llvm-symbolizer.exe"
            }
         ],
         "console": "integratedTerminal"
      },
      {
         "name": "(Windows) Launch promise_test",
         "type": "cppvsdbg",
         "request": "launch",
         "program": "${workspaceFolder}/build/_deps/promise-build/test/promise_test.exe",
         "args": [],
         "stopAtEntry": false,
         "cwd": "${workspaceFolder}",
         "environment": [
            {
               "name": "ASAN_OPTIONS",
               "value": "halt_on_error=1:verbosity=1:check_initialization_order=1:detect_leaks=0:detect_stack_use_after_return=1:alloc_dealloc_mismatch=1:detect_invalid_pointer_pairs=1:strict_string_checks=1:print_summary=1"
            },
            {
               "name": "ASAN_SYMBOLIZER_PATH",
               "value": "C:/Program Files/LLVM/bin/llvm-symbolizer.exe"
            }
         ],
         "console": "integratedTerminal"
      },
      {
         "name": "(Windows) Launch Packager",
         "type": "cppvsdbg",
         "request": "attach",
         "processId": "${command:pickProcess}"
         // "program": "${workspaceFolder}/build/packager/packager.exe",
         // "args": [
         //    "C:/Users/alexg/Documents/workspace/msfs2024-vfrnav-efb-installer/build/server",
         //    "--app",
         //    "resources",
         //    "C:/Users/alexg/Documents/workspace/msfs2024-vfrnav-efb-installer/build/server/app/dist"
         // ],
         // "stopAtEntry": false,
         // "cwd": "${fileDirname}",
         // "environment": [],
         // "console": "integratedTerminal"
      }
   ]
}
